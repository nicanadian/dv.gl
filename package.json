{
  "name": "dvgl-monorepo",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm run build:packages && pnpm run build:viewer && pnpm run build:proximity && pnpm --filter @dvgl/bench-runner build",
    "typecheck": "pnpm run build:packages && pnpm run build:viewer && pnpm -r --workspace-concurrency=4 run typecheck",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write .",
    "build:packages": "tsc -b tsconfig.json",
    "build:viewer": "pnpm --filter @dvgl/viewer build",
    "build:proximity": "pnpm --filter @dvgl/proximity-viewer build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "earcut": "3.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
